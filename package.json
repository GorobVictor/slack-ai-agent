{
  "name": "slack-ai-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/bot/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bot/index.js",
    "check": "tsc --noEmit",
    "worker:dev": "wrangler dev --config src/worker/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config src/worker/wrangler.jsonc",
    "worker:types": "wrangler types --config src/worker/wrangler.jsonc src/worker/env.d.ts",
    "worker:check": "tsc -p src/worker/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.2",
    "agents": "^0.13.3",
    "better-sqlite3": "^12.10.0",
    "pdf-parse": "^2.4.5",
    "read-excel-file": "^9.0.10"
  }
}
