{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "slack-ai-agent-worker",
  "main": "server.ts",
  "compatibility_date": "2026-05-27",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "SLACK_THREAD_AGENT",
        "class_name": "SlackThreadAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SlackThreadAgent"]
    }
  ],
  "vars": {
    "WORKERS_AI_MODEL": "@cf/google/gemma-4-26b-a4b-it",
    "AI_SYSTEM_PROMPT": "You are a helpful assistant inside Slack. Answer clearly and concisely. Use the Slack thread context when it is useful. Reply in the same language the user used in their latest message. If the language is ambiguous, match the dominant language in the current Slack thread.",
    "AI_MAX_TOKENS": 700,
    "AI_TEMPERATURE": 0.4,
    "AI_MAX_THREAD_MESSAGES": 20
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
